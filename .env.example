# Firebase Admin (server only — never NEXT_PUBLIC)
# Option A (easiest local dev): download JSON key, save as firebase-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
FIREBASE_PROJECT_ID=pets-acd3f

# Option B (production / Vercel): paste from the same JSON file
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Firebase client (public)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=pets-acd3f.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=pets-acd3f
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=pets-acd3f.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
