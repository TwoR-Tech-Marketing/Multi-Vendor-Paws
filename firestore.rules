rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isVendor() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor';
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /vendors/{vendorId} {
      allow read, write: if isOwner(vendorId) && isVendor();
    }

    match /vendor_signup_requests/{requestId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn()
        && (resource.data.authUid == request.auth.uid
          || resource.data.email == request.auth.token.email);
      allow update, delete: if false;
    }

    match /vendor_profile_change_requests/{requestId} {
      allow create: if isSignedIn()
        && request.resource.data.authUid == request.auth.uid
        && request.resource.data.vendorId == request.auth.uid;
      allow read: if isSignedIn()
        && resource.data.authUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /products/{productId} {
      allow read, write: if isSignedIn()
        && resource.data.vendorId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.vendorId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow read, update: if isSignedIn()
        && resource.data.vendorId == request.auth.uid;
      allow create: if false;
    }

    match /vendorEarnings/{vendorId}/entries/{entryId} {
      allow read: if isOwner(vendorId) && isVendor();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
